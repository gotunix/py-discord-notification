# =============================================================================
# Discord Notifier Bot + Pyramid Webhook Server
# =============================================================================

# --- Discord Bot Settings ---
# Generate your bot token at: https://discord.com/developers/applications
DISCORD_BOT_TOKEN="your_discord_bot_token_here_xxxx"

# A comma-separated list of Discord user IDs allowed to send commands to the bot via DMs.
# Example: 184512345678901234, 123456789012345678
ALLOWED_USER_IDS=""

# --- Webhook Notification Targets ---
# Default Discord channel ID (e.g. #monitoring) to post incoming notifications to.
# Example: 112233445566778899
NOTIFY_CHANNEL_ID=""

# Comma-separated Discord user IDs to notify via DMs when a new webhook reaches the app.
# Example: 184512345678901234, 123456789012345678
NOTIFY_USER_IDS=""

# --- Webhook Server Settings ---
# The interface to bind to (0.0.0.0 is the default inside Docker).
SERVER_HOST="0.0.0.0"

# The port to listen on. This is internally used by the container.
# If you change this, update your docker-compose mappings too.
SERVER_PORT=8765

# Shared secret for authenticating incoming webhook requests.
# Senders must include:  Authorization: Bearer <WEBHOOK_SECRET>
# Use a strong randomly generated string here.
WEBHOOK_SECRET="change-this-to-a-secure-secret-token"
